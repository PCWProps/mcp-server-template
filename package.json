{
  "name": "@pcwprops/mcp-server-template",
  "version": "0.1.0",
  "description": "Enterprise-grade MCP server template for Cloudflare Workers — bridge any REST API to the Model Context Protocol",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "PCWProps",
    "url": "https://github.com/PCWProps"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PCWProps/mcp-server-template.git"
  },
  "bugs": {
    "url": "https://github.com/PCWProps/mcp-server-template/issues"
  },
  "homepage": "https://github.com/PCWProps/mcp-server-template#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cloudflare-workers",
    "ai",
    "llm",
    "anthropic",
    "hono",
    "typescript",
    "edge"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src scripts --max-warnings 0",
    "lint:fix": "eslint src scripts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"*.json\" \"*.toml\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "changeset": "changeset",
    "ingest-openapi": "tsx scripts/ingest-openapi.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@hono/zod-validator": "^0.4.0",
    "hono": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@cloudflare/workers-types": "^4.20241022.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.40.0"
  },
  "pnpm": {
    "overrides": {}
  }
}
